varnishtest "vmod-wasm: memory limit prevents excessive allocation"

# This test verifies:
# 1. A Wasm module that tries to grow memory beyond the limit is trapped
# 2. The request completes with an error instead of exhausting host memory
# 3. Normal execution still works after a memory trap

server s1 {
    rxreq
    txresp -status 200 -body "OK"
    rxreq
    txresp -status 200 -body "OK"
} -start

varnish v1 -vcl+backend {
    import wasm from "${vmod_wasm}";

    sub vcl_init {
        wasm.load("test", "${wasm_module}");
        # Set a 2 MiB memory limit — grow_memory tries 32 MiB
        wasm.set_memory_limit(2097152);
        # Give plenty of fuel so we hit the memory limit, not fuel
        wasm.set_fuel(100000000);
    }

    sub vcl_recv {
        set req.http.X-Wasm-Result = wasm.execute("test", req.http.X-Wasm-Func);
    }

    sub vcl_deliver {
        set resp.http.X-Wasm-Result = req.http.X-Wasm-Result;
    }
} -start

# Test 1: grow_memory should fail due to memory limit
client c1 {
    txreq -url "/" -hdr "X-Wasm-Func: grow_memory"
    rxresp
    expect resp.status == 200
    # execute() returns -1 when the Wasm call fails (trap)
    expect resp.http.X-Wasm-Result == "-1"
} -run

# Test 2: normal function still works after memory trap
client c2 {
    txreq -url "/" -hdr "X-Wasm-Func: get_constant"
    rxresp
    expect resp.status == 200
    expect resp.http.X-Wasm-Result == "42"
} -run
